{
  "name": "prostcounter",
  "version": "0.9.1",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@prostcounter/web",
    "dev:web:lan": "pnpm --filter @prostcounter/web dev:lan",
    "dev:mobile": "turbo dev --filter=@prostcounter/mobile",
    "dev:mobile:device": "pnpm --filter @prostcounter/mobile dev:device",
    "build": "turbo build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "sup:db:pull": "supabase db pull",
    "sup:db:push": "supabase db push",
    "sup:db:reset": "supabase db reset",
    "sup:db:types": "supabase gen types typescript --local > packages/db/src/types.ts",
    "sup:mig:new": "supabase migration new",
    "sup:start": "supabase start",
    "sup:stop": "supabase stop",
    "sup:restart": "supabase stop && supabase start",
    "api:generate-spec": "turbo api:generate-spec",
    "client:generate": "turbo client:generate",
    "api:generate": "pnpm api:generate-spec && pnpm client:generate",
    "clean": "turbo clean && rm -rf node_modules",
    "version:show": "tsx scripts/version.ts show",
    "version:patch": "tsx scripts/version.ts patch",
    "version:minor": "tsx scripts/version.ts minor",
    "version:major": "tsx scripts/version.ts major",
    "version:set": "tsx scripts/version.ts set",
    "release:patch": "pnpm run version:patch && git add . && git commit -m \"chore: bump version\" && git tag v$(pnpm exec tsx scripts/version.ts show) && git push && git push --tags",
    "release:minor": "pnpm run version:minor && git add . && git commit -m \"chore: bump version\" && git tag v$(pnpm exec tsx scripts/version.ts show) && git push && git push --tags",
    "release:major": "pnpm run version:major && git add . && git commit -m \"chore: bump version\" && git tag v$(pnpm exec tsx scripts/version.ts show) && git push && git push --tags",
    "prepare": "husky",
    "cron:trigger": "tsx scripts/trigger-cron.ts",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:install-browsers": "playwright install --with-deps",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "expo": "~55.0.19",
    "react": "19.2.5",
    "react-native": "0.83.2"
  },
  "devDependencies": {
    "@novu/api": "^3.16.0",
    "@playwright/test": "^1.59.1",
    "dotenv": "^17.4.2",
    "husky": "^9.1.7",
    "next": "16.2.6",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "supabase": "2.98.0",
    "tsx": "^4.21.0",
    "turbo": "^2.9.15",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20 <25"
  },
  "packageManager": "pnpm@10.14.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@firebase/util",
      "@sentry/cli",
      "@swc/core",
      "@tailwindcss/oxide",
      "@vercel/speed-insights",
      "esbuild",
      "protobufjs",
      "sharp",
      "supabase",
      "unrs-resolver"
    ],
    "overrides": {
      "lightningcss": "1.30.1",
      "patch-package": "8.0.1",
      "esbuild": ">=0.25.0",
      "seroval": ">=1.4.1",
      "tar": ">=7.5.7",
      "fast-xml-parser": ">=5.7.0",
      "react": "19.2.5",
      "react-dom": "19.2.5",
      "@isaacs/brace-expansion": "5.0.1",
      "@xmldom/xmldom": "0.8.13",
      "protobufjs": ">=7.5.8",
      "liquidjs": ">=10.26.0",
      "socket.io-parser": ">=4.2.6",
      "node-forge": ">=1.4.0",
      "vite": "7.3.3",
      "postcss": ">=8.5.13",
      "yaml": ">=2.8.3",
      "qs": ">=6.15.2",
      "fast-uri": ">=3.1.2",
      "tmp": ">=0.2.6",
      "ws@8": ">=8.20.1",
      "picomatch@2": ">=2.3.2",
      "picomatch@4": ">=4.0.4",
      "brace-expansion@1": ">=1.1.13",
      "brace-expansion@2": ">=2.0.3",
      "brace-expansion@5": ">=5.0.6"
    }
  }
}
