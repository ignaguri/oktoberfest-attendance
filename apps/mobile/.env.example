# Supabase
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-start

# API URL (local development)
EXPO_PUBLIC_API_URL=http://localhost:3008/api

# Watch API URL override (Info.plist key for the watchOS target)
# Only needed when running on a physical Apple Watch, since "localhost"
# on the watch resolves to the watch itself. Must include /api/v1.
# Leave empty to use the Debug (localhost:3008) / Release (prod) defaults.
EXPO_PUBLIC_WATCH_API_BASE_URL=

# Novu (notifications)
EXPO_PUBLIC_NOVU_APP_ID=your-novu-app-id

# EAS Project ID (for Expo push notifications)
# Get this by running: eas project:show
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id

# Google Maps API Key (Android only)
# Get this from Google Cloud Console: https://console.cloud.google.com/apis/credentials
# Restrict the key to Android apps with your package name (com.prostcounter.app)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Sentry (error monitoring)
# Get these from Sentry project settings: https://sentry.io/settings/
# Optional - leave empty to disable error monitoring
EXPO_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# Vexo (analytics)
# Get this from your Vexo dashboard: https://vexo.co
# Optional - leave empty to disable analytics
EXPO_PUBLIC_VEXO_API_KEY=
