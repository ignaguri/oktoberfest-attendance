{
  "name": "@prostcounter/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:clean": "expo start --clear",
    "dev": "expo start",
    "dev:device": "[ -f .env ] && cp .env .env.bak; cp .env.device .env && expo start",
    "dev:sim": "cp .env.local .env && expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:device": "[ -f .env ] && cp .env .env.bak; cp .env.device .env && expo run:ios",
    "ios:clean": "expo prebuild --clean && expo run:ios",
    "web": "expo start --web",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "type-check": "tsc --noEmit",
    "prebuild": "expo prebuild",
    "test": "vitest run",
    "test:watch": "vitest --watch"
  },
